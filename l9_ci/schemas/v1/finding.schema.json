{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/l9-ci-sdk/v1/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "snapshot_id",
    "provider_id",
    "provider_rule_id",
    "category",
    "message",
    "evidence_ids",
    "locations",
    "fingerprint",
    "attributes",
    "limitations"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "$ref": "source-location.schema.json"
      }
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "attributes": {
      "type": "object"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonical_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational",
        "unknown"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "remediation_class": {
      "type": "string",
      "minLength": 1
    }
  }
}
