{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/l9-ci-sdk/v1/repository-snapshot.schema.json",
  "title": "RepositorySnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "dirty",
    "files",
    "file_count",
    "source"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": [
        "string",
        "null"
      ]
    },
    "dirty": {
      "type": "boolean"
    },
    "files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
      }
    },
    "file_count": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "enum": [
        "git",
        "filesystem"
      ]
    }
  }
}
