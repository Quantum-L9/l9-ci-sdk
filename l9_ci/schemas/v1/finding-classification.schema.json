{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/l9-ci-sdk/v1/finding-classification.schema.json",
  "title": "FindingClassification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "mode",
    "resolution_status",
    "used_default"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "blocking",
        "advisory",
        "shadow",
        "disabled",
        "unresolved"
      ]
    },
    "resolution_status": {
      "enum": [
        "explicit",
        "defaulted",
        "unresolved"
      ]
    },
    "used_default": {
      "type": "boolean"
    },
    "policy_key": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "waiver_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resolution_status": {
            "const": "explicit"
          }
        }
      },
      "then": {
        "required": ["policy_key"]
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "unresolved"
          }
        }
      },
      "then": {
        "properties": {
          "resolution_status": {
            "const": "unresolved"
          }
        }
      }
    }
  ]
}
