{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/l9-ci-sdk/v1/evidence-record.schema.json",
  "title": "EvidenceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "snapshot_id",
    "provider_id",
    "provider_rule_id",
    "evidence_type",
    "message",
    "locations",
    "attributes",
    "limitations",
    "identifiers"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_type": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "locations": {
      "type": "array",
      "items": {
        "$ref": "source-location.schema.json"
      }
    },
    "attributes": {
      "type": "object"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provider_version": {
      "type": "string",
      "minLength": 1
    },
    "canonical_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational",
        "unknown"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "provider_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
